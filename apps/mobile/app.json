{
  "expo": {
    "name": "MarketLoop",
    "slug": "marketloop-mobile",
    "scheme": "marketloop",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-asset"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.marketloop.mobile"
    },
    "android": {
      "package": "com.marketloop.mobile"
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
