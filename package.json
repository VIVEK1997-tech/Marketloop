{
  "name": "olx-style-marketplace",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "install:mobile": "npm install --prefix apps/mobile",
    "start": "npm start --prefix backend",
    "build": "npm run build --prefix frontend",
    "dev:mobile": "npm run dev --prefix apps/mobile",
    "typecheck:mobile": "npm run typecheck --prefix apps/mobile"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
